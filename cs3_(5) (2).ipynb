    {
      "cell_type": "code",
      "source": [
        "threshold = 0.001\n",
        "\n",
        "df[\"yhat_shift1\"] = df[\"yhat\"].shift(1)  # prognoza na dzisiejszy dzień wygenerowana wczoraj\n",
        "df[\"signal\"] = 0\n",
        "\n",
        "#wejście w longa\n",
        "long_cond = (\n",
        "    (df[\"yhat_shift1\"] > df[\"Close\"] * (1 + threshold)) &\n",
        "    (df[\"Close\"] > df[\"SMA_20\"]) &\n",
        "    (df[\"RSI\"] < 70)\n",
        ")\n",
        "\n",
        "df.loc[long_cond, \"signal\"] = 1\n"
      ],
