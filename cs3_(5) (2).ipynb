        "\n",
        "# TEST: 2024\n",
        "test_data = data.loc['2024-01-01':'2024-12-31'].copy()\n",
        "test_data['Prediction'] = df.loc['2024-01-01':'2024-12-31', 'yhat']\n"
      ],
